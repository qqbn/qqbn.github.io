---
import HeroCanvas from './HeroCanvas.astro';
---

<section id="hero" class="hero">
  <div class="container hero-inner">
    <div class="hero-content" data-aos="fade-up">
      <h1 class="hero-name">Jakub Kroc</h1>
      <p class="hero-role">Frontend Developer</p>
      <p class="hero-tagline">
        I craft fast, accessible, and polished web interfaces — from wireframe to production.
      </p>
    </div>
    <div class="mouse"></div>

    <div class="hero-visual" data-aos="fade-up" data-aos-delay="150">
      <HeroCanvas />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: linear-gradient(160deg, var(--color-hero-bg-start) 0%, var(--color-hero-bg-end) 100%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    align-items: center;
    gap: clamp(2rem, 6vw, 4rem);
  }

  .hero-name {
    font-family: var(--font-hero);
    font-weight: 800;
    font-size: clamp(3rem, 9vw, 6rem);
    letter-spacing: -0.02em;
    color: var(--color-accent-cyan-dark);
    margin-bottom: 0.5rem;
  }

  .hero-role {
    font-family: var(--font-hero);
    font-weight: 600;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    color: var(--color-hero-text-secondary);
    margin-bottom: 1.25rem;
  }

  .hero-tagline {
    max-width: 42ch;
    font-family: var(--font-hero);
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    color: var(--color-hero-text-primary);
    margin-bottom: 2rem;
  }

  .hero-visual {
    width: 100%;
    height: clamp(260px, 40vw, 480px);
  }

  .hero .btn {
    border-color: var(--color-accent-cyan-dark);
    color: var(--color-accent-cyan-dark);
  }

  .hero .btn:hover,
  .hero .btn:focus-visible {
    background-color: var(--color-accent-cyan-dark);
    color: #fff;
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-tagline {
      margin-inline: auto;
    }

    .hero-visual {
      height: clamp(220px, 70vw, 360px);
      order: -1;
    }
  }

  .mouse {
    width: 20px;
    height: 40px;
    border: 1px solid var(--color-hero-text-primary);
    border-radius: 60px;
    position: absolute;
    top: 80%;
    left: 50%;
    transform: translateX(-50%);
          &::before {
              content: '';
              width: 6px;
              height: 6px;
              position: absolute;
              top: 10px;
              left: 50%;
              transform: translateX(-50%);
              background-color: var(--color-hero-text-primary);
              border-radius: 50%;
              opacity: 1;
              animation: wheel 2s infinite;
              -webkit-animation: wheel 2s infinite;
          }
      }

    @keyframes wheel {
        to {
            opacity: 0;
            top: 30px;
        }
    }

    @-webkit-keyframes wheel {
        to {
            opacity: 0;
            top: 30px;
        }
    }
</style>
