---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import avatar2 from '../assets/avatar2.png';

const allProjects = await getCollection('projects');

const projects = [...allProjects].sort((a, b) => a.data.order - b.data.order);

const PAGE_SIZE = 4;
const pages: typeof projects[] = [];
for (let i = 0; i < projects.length; i += PAGE_SIZE) {
  pages.push(projects.slice(i, i + PAGE_SIZE));
}
---

<section id="projects" class="section projects">
  <div class="container">
    <div class="projects-heading">
      <div class="projects-intro">
        <h2 class="section-title">My <span>projects</span></h2>
        <p class="projects-text">
          A selection of personal and side projects built to explore new technologies, solve real
          problems, and sharpen skills beyond the day-to-day. Each project includes a live demo
          and a GitHub repository.
        </p>
      </div>
      <div class="projects-avatar">
        <Image src={avatar2} alt="" class="projects-avatar-img" width={360} height={360} loading="lazy" />
      </div>
    </div>

    <div class="projects-slider">
      {pages.length > 1 && (
        <button class="projects-arrow projects-arrow--prev" id="projects-prev" type="button" aria-label="Poprzednie projekty">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M19 12H5" />
            <path d="M11 18l-6-6 6-6" />
          </svg>
        </button>
      )}

      <div class="projects-viewport" id="projects-viewport">
      <div class="projects-track" id="projects-track">
        {pages.map((page) => (
          <div class="projects-page">
            {page.map((project, index) => (
              <article class="project-card" data-aos="fade-up" data-aos-delay={index * 100}>
                <div class="project-card-header">
                  <h3 class="project-card-title">{project.data.title}</h3>
                </div>

                <p class="project-card-description">{project.data.description}</p>

                <ul class="project-card-tech">
                  {project.data.tech.map((tech) => (
                    <li class="project-card-tech-item">{tech}</li>
                  ))}
                </ul>

                <div class="project-card-links">
                  <a
                    href={project.data.github}
                    class="project-card-link"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Zobacz repozytorium ${project.data.title} na GitHub`}
                  >
                    <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false">
                      <path
                        fill="currentColor"
                        d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.03 1.75 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.2-1.49 3.17-1.18 3.17-1.18.63 1.58.24 2.75.12 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.07.78 2.16 0 1.56-.01 2.81-.01 3.19 0 .31.21.66.79.55A10.99 10.99 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"
                      ></path>
                    </svg>
                  </a>

                  {project.data.live && (
                    <a
                      href={project.data.live}
                      class="project-card-link"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`Otwórz live demo projektu ${project.data.title}`}
                    >
                      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false">
                        <path
                          fill="currentColor"
                          d="M14 3a1 1 0 1 0 0 2h3.59l-9.3 9.29a1 1 0 0 0 1.42 1.42L19 6.41V10a1 1 0 1 0 2 0V4a1 1 0 0 0-1-1h-6zM5 5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5a1 1 0 1 0-2 0v5H5V7h5a1 1 0 1 0 0-2H5z"
                        ></path>
                      </svg>
                    </a>
                  )}
                </div>
              </article>
            ))}
          </div>
        ))}
      </div>
      </div>

      {pages.length > 1 && (
        <button class="projects-arrow projects-arrow--next" id="projects-next" type="button" aria-label="Następne projekty">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M5 12h14" />
            <path d="M13 6l6 6-6 6" />
          </svg>
        </button>
      )}
    </div>

    {pages.length > 1 && (
      <div class="projects-dots" id="projects-dots" role="tablist" aria-label="Strony projektów">
        {pages.map((_, index) => (
          <button
            class="projects-dot"
            class:list={[{ 'is-active': index === 0 }]}
            type="button"
            role="tab"
            aria-label={`Przejdź do strony ${index + 1}`}
            aria-selected={index === 0}
            data-index={index}
          ></button>
        ))}
      </div>
    )}

    {projects.length > 1 && (
      <div class="projects-swipe-hint" aria-hidden="true">
        <span class="projects-swipe-icon">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M13 5l7 7-7 7" />
            <path d="M3 12h16" />
          </svg>
        </span>
        Swipe to see more projects
      </div>
    )}
  </div>
</section>

<style>
  .projects-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(1.5rem, 4vw, 3rem);
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .projects-intro .section-title {
    margin-bottom: 0.75rem;
  }

  .projects-text {
    max-width: 60ch;
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 2vw, 1.15rem);
  }

  .projects-avatar {
    position: relative;
    flex-shrink: 0;
    width: clamp(10rem, 20vw, 16rem);
    height: clamp(10rem, 20vw, 16rem);
    border: 2px solid color-mix(in srgb, var(--color-accent-cyan) 40%, transparent);
    border-radius: 50%;
    background-color: var(--color-bg-secondary);
    overflow: hidden;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .projects-avatar:hover {
    border-color: var(--color-accent-cyan);
    transform: scale(1.03);
  }

  .projects-avatar-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .projects-avatar {
      display: none;
    }
  }

  .projects-slider {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .projects-arrow {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background-color: var(--color-bg-secondary);
    border: 1px solid color-mix(in srgb, var(--color-accent-cyan) 35%, transparent);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: border-color var(--transition-base), color var(--transition-base), transform var(--transition-base);
  }

  .projects-arrow:hover,
  .projects-arrow:focus-visible {
    border-color: var(--color-accent-cyan);
    color: var(--color-accent-cyan);
    transform: translateY(-2px);
  }

  .projects-arrow:disabled {
    opacity: 0.35;
    cursor: default;
    transform: none;
  }

  .projects-viewport {
    flex: 1;
    overflow: hidden;
  }

  .projects-track {
    display: flex;
    transition: transform 0.5s ease;
  }

  .projects-page {
    flex: 0 0 100%;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    align-content: start;
    padding: 0.75rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .projects-track {
      transition: none;
    }
  }

  @media (max-width: 768px) {
    .projects-slider {
      gap: 0.5rem;
    }

    .projects-viewport {
      overflow-x: auto;
      overflow-y: visible;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-block: 0.75rem;
      touch-action: pan-x;
    }

    .projects-viewport::-webkit-scrollbar {
      display: none;
    }

    .projects-track {
      transition: none;
      gap: 1rem;
    }

    .projects-page {
      display: contents;
    }

    .project-card {
      flex: 0 0 calc(100% - 1rem);
      scroll-snap-align: center;
    }
  }

  .projects-dots {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    margin-top: clamp(1.5rem, 4vw, 2.5rem);
  }

  .projects-dot {
    width: 0.6rem;
    height: 0.6rem;
    padding: 0;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--color-accent-cyan) 40%, transparent);
    background-color: transparent;
    cursor: pointer;
    transition: background-color var(--transition-base), border-color var(--transition-base), transform var(--transition-base);
  }

  .projects-dot:hover,
  .projects-dot:focus-visible {
    border-color: var(--color-accent-cyan);
  }

  .projects-dot.is-active {
    background-color: var(--color-accent-cyan);
    border-color: var(--color-accent-cyan);
    transform: scale(1.2);
  }

  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    background-color: var(--color-bg-secondary);
    border: 1px solid color-mix(in srgb, var(--color-text-primary) 6%, transparent);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 1.75rem;
    width: 2.5rem;
    height: 3px;
    border-radius: 0 0 999px 999px;
    background: linear-gradient(90deg, var(--color-accent-cyan), var(--color-accent-pink));
    opacity: 0.85;
    transition: opacity var(--transition-base), width var(--transition-base);
  }

  .project-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-accent-cyan) 10%, transparent), color-mix(in srgb, var(--color-accent-pink) 10%, transparent));
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .project-card:hover {
    border-color: var(--color-accent-cyan);
    transform: translateY(-4px);
  }

  .project-card:hover::before {
    opacity: 1;
    width: 4rem;
  }

  .project-card:hover::after {
    opacity: 1;
  }

  .project-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .project-card-title {
    font-size: 1.25rem;
    color: var(--color-text-primary);
  }

  .project-card-description {
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
  }

  .project-card-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .project-card-tech-item {
    font-size: 0.8rem;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background-color: var(--color-bg-primary);
    border: 1px solid color-mix(in srgb, var(--color-accent-cyan) 35%, transparent);
    color: var(--color-text-primary);
  }

  .project-card-links {
    display: flex;
    gap: 1rem;
    margin-top: auto;
  }

  .project-card-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-primary);
    transition: color var(--transition-base);
  }

  .project-card-link:hover,
  .project-card-link:focus-visible {
    color: var(--color-accent-cyan);
  }

  .projects-swipe-hint {
    display: none;
  }

  @media (max-width: 768px) {
    .projects-arrow,
    .projects-dots {
      display: none;
    }

    .projects-swipe-hint {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 1.25rem;
      padding: 0.6rem 1.25rem;
      border-radius: 999px;
      background-color: var(--color-bg-secondary);
      border: 1px solid color-mix(in srgb, var(--color-accent-cyan) 35%, transparent);
      color: var(--color-text-secondary);
      font-size: 0.8rem;
      text-align: center;
    }

    .projects-swipe-icon {
      display: inline-flex;
      color: var(--color-accent-cyan);
      animation: swipe-hint-move 1.6s ease-in-out infinite;
    }
  }

  @keyframes swipe-hint-move {
    0%, 100% {
      transform: translateX(0);
      opacity: 0.5;
    }
    50% {
      transform: translateX(6px);
      opacity: 1;
    }
  }
</style>

<script>
  const track = document.getElementById('projects-track');
  const viewport = document.getElementById('projects-viewport');
  const prevBtn = document.getElementById('projects-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('projects-next') as HTMLButtonElement | null;
  const dots = document.querySelectorAll<HTMLButtonElement>('.projects-dot');

  if (track) {
    const pageCount = track.children.length;
    const mobileQuery = window.matchMedia('(max-width: 768px)');
    let isMobile = mobileQuery.matches;
    let currentPage = 0;
    let wheelLocked = false;

    function update() {
      if (!track) return;

      if (isMobile) {
        track.style.transform = '';
        return;
      }

      track.style.transform = `translateX(-${currentPage * 100}%)`;

      if (prevBtn) prevBtn.disabled = currentPage === 0;
      if (nextBtn) nextBtn.disabled = currentPage === pageCount - 1;

      dots.forEach((dot, index) => {
        const isActive = index === currentPage;
        dot.classList.toggle('is-active', isActive);
        dot.setAttribute('aria-selected', String(isActive));
      });
    }

    function goTo(page: number) {
      currentPage = Math.max(0, Math.min(pageCount - 1, page));
      update();
    }

    prevBtn?.addEventListener('click', () => goTo(currentPage - 1));
    nextBtn?.addEventListener('click', () => goTo(currentPage + 1));

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => goTo(index));
    });

    viewport?.addEventListener(
      'wheel',
      (event) => {
        if (isMobile || pageCount <= 1) return;

        if (Math.abs(event.deltaX) <= Math.abs(event.deltaY)) return;
        if (Math.abs(event.deltaX) < 10) return;

        const next = event.deltaX > 0 ? currentPage + 1 : currentPage - 1;
        if (next === currentPage || next < 0 || next > pageCount - 1) return;

        event.preventDefault();
        if (wheelLocked) return;

        wheelLocked = true;
        goTo(next);
        setTimeout(() => {
          wheelLocked = false;
        }, 600);
      },
      { passive: false }
    );

    update();

    mobileQuery.addEventListener('change', (event) => {
      isMobile = event.matches;
      if (isMobile) {
        track.style.transform = '';
      }
      update();
    });
  }
</script>
