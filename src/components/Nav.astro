---
const links = [
  { href: '#about-me', label: 'About me' },
  { href: '#projects', label: 'Projects' },
  { href: '#contact', label: 'Contact' },
];
---

<nav class="float-nav" aria-label="Nawigacja sekcji">
  <ul class="float-nav-list">
    {links.map((link, index) => (
      <li class={`float-nav-item float-nav-item--${index % 3}`}>
        <a href={link.href} class="float-nav-link">{link.label}</a>
      </li>
    ))}
    <li class="float-nav-item float-nav-item--1">
      <button
        class="float-nav-link theme-toggle"
        type="button"
        aria-label="Przełącz motyw jasny/ciemny"
      >
        <svg class="icon-sun" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
          <path
            fill="currentColor"
            d="M12 4a1 1 0 0 1-1-1V1a1 1 0 1 1 2 0v2a1 1 0 0 1-1 1zm0 19a1 1 0 0 1-1-1v-2a1 1 0 1 1 2 0v2a1 1 0 0 1-1 1zm9-11a1 1 0 0 1 1-1h2a1 1 0 1 1 0 2h-2a1 1 0 0 1-1-1zM1 12a1 1 0 0 1 1-1h2a1 1 0 1 1 0 2H2a1 1 0 0 1-1-1zm17.66-6.66a1 1 0 0 1 0-1.41l1.42-1.42a1 1 0 1 1 1.41 1.42l-1.41 1.41a1 1 0 0 1-1.42 0zM3.51 20.49a1 1 0 0 1 0-1.42l1.41-1.41a1 1 0 1 1 1.42 1.41l-1.42 1.42a1 1 0 0 1-1.41 0zm15.56 0a1 1 0 0 1-1.41 0l-1.42-1.42a1 1 0 1 1 1.42-1.41l1.41 1.41a1 1 0 0 1 0 1.42zM4.93 5.93a1 1 0 0 1-1.42 0L2.1 4.51A1 1 0 1 1 3.51 3.1l1.42 1.42a1 1 0 0 1 0 1.41zM12 6a6 6 0 1 1 0 12 6 6 0 0 1 0-12z"
          ></path>
        </svg>
        <svg class="icon-moon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
          <path
            fill="currentColor"
            d="M21.64 13a1 1 0 0 0-1.05-.14 8.05 8.05 0 0 1-3.37.73 8.15 8.15 0 0 1-8.14-8.1 8.59 8.59 0 0 1 .25-2A1 1 0 0 0 8 2.36a10.14 10.14 0 1 0 13.69 13.7 1 1 0 0 0-.05-1.06z"
          ></path>
        </svg>
      </button>
    </li>
  </ul>

  <button
    class="nav-trigger"
    id="nav-trigger"
    type="button"
    aria-label="Otwórz menu nawigacji"
    aria-expanded="false"
    aria-controls="mobile-nav-sheet"
  >
    <span class="nav-trigger-icon" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </span>
  </button>

  <div class="nav-backdrop" id="nav-backdrop"></div>

  <div class="nav-sheet" id="mobile-nav-sheet">
    <div class="nav-sheet-handle" aria-hidden="true"></div>
    <button class="nav-sheet-close" id="nav-close" type="button" aria-label="Zamknij menu">
      <svg
        viewBox="0 0 24 24"
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
        focusable="false"
      >
        <path d="M6 6l12 12"></path>
        <path d="M18 6 6 18"></path>
      </svg>
    </button>
    <ul class="nav-sheet-list">
      {links.map((link) => (
        <li>
          <a href={link.href} class="nav-sheet-link">{link.label}</a>
        </li>
      ))}
      <li>
        <button class="nav-sheet-link theme-toggle" type="button" aria-label="Przełącz motyw jasny/ciemny">
          <svg class="icon-sun" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
            <path
              fill="currentColor"
              d="M12 4a1 1 0 0 1-1-1V1a1 1 0 1 1 2 0v2a1 1 0 0 1-1 1zm0 19a1 1 0 0 1-1-1v-2a1 1 0 1 1 2 0v2a1 1 0 0 1-1 1zm9-11a1 1 0 0 1 1-1h2a1 1 0 1 1 0 2h-2a1 1 0 0 1-1-1zM1 12a1 1 0 0 1 1-1h2a1 1 0 1 1 0 2H2a1 1 0 0 1-1-1zm17.66-6.66a1 1 0 0 1 0-1.41l1.42-1.42a1 1 0 1 1 1.41 1.42l-1.41 1.41a1 1 0 0 1-1.42 0zM3.51 20.49a1 1 0 0 1 0-1.42l1.41-1.41a1 1 0 1 1 1.42 1.41l-1.42 1.42a1 1 0 0 1-1.41 0zm15.56 0a1 1 0 0 1-1.41 0l-1.42-1.42a1 1 0 1 1 1.42-1.41l1.41 1.41a1 1 0 0 1 0 1.42zM4.93 5.93a1 1 0 0 1-1.42 0L2.1 4.51A1 1 0 1 1 3.51 3.1l1.42 1.42a1 1 0 0 1 0 1.41zM12 6a6 6 0 1 1 0 12 6 6 0 0 1 0-12z"
            ></path>
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
            <path
              fill="currentColor"
              d="M21.64 13a1 1 0 0 0-1.05-.14 8.05 8.05 0 0 1-3.37.73 8.15 8.15 0 0 1-8.14-8.1 8.59 8.59 0 0 1 .25-2A1 1 0 0 0 8 2.36a10.14 10.14 0 1 0 13.69 13.7 1 1 0 0 0-.05-1.06z"
            ></path>
          </svg>
          <span>Toggle theme</span>
        </button>
      </li>
    </ul>
  </div>
</nav>

<style>
  .float-nav {
    position: fixed;
    top: 2.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
  }

  .float-nav-list {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: clamp(2rem, 5vw, 3.5rem);
  }

  .float-nav-item {
    display: flex;
  }

  .float-nav-item--0 {
    animation: float-a 6s ease-in-out infinite;
  }

  .float-nav-item--1 {
    animation: float-b 7s ease-in-out infinite;
    animation-delay: -1.5s;
  }

  .float-nav-item--2 {
    animation: float-c 5.5s ease-in-out infinite;
    animation-delay: -3s;
  }

  .float-nav-link {
    position: relative;
    display: inline-block;
    padding: 0.4rem 0.6rem;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: var(--color-accent-cyan-dark);
    transition: color var(--transition-base), transform var(--transition-base);
  }

  .float-nav-link::after {
    content: '';
    position: absolute;
    left: 0.6rem;
    right: 0.6rem;
    bottom: 0.1rem;
    height: 2px;
    border-radius: 999px;
    background-color: var(--color-accent-pink);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--transition-base);
  }

  .float-nav-link:hover,
  .float-nav-link:focus-visible {
    color: var(--color-accent-pink);
    transform: translateY(-2px) scale(1.1);
  }

  .float-nav-link:hover::after,
  .float-nav-link:focus-visible::after {
    transform: scaleX(1);
  }

  .theme-toggle {
    background: transparent;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .float-nav-link.theme-toggle::after {
    display: none;
  }

  .icon-moon {
    display: none;
  }

  :global(html[data-theme='light']) .theme-toggle .icon-sun {
    display: none;
  }

  :global(html[data-theme='light']) .theme-toggle .icon-moon {
    display: block;
  }

  @keyframes float-a {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(3px, -10px) rotate(1.5deg); }
    50% { transform: translate(-2px, -4px) rotate(-1deg); }
    75% { transform: translate(-4px, -12px) rotate(1deg); }
  }

  @keyframes float-b {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    30% { transform: translate(-4px, -8px) rotate(-1.5deg); }
    60% { transform: translate(3px, -14px) rotate(1.5deg); }
    85% { transform: translate(2px, -5px) rotate(-1deg); }
  }

  @keyframes float-c {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    20% { transform: translate(4px, -6px) rotate(1deg); }
    55% { transform: translate(-3px, -13px) rotate(-1.5deg); }
    80% { transform: translate(2px, -8px) rotate(1.5deg); }
  }

  .nav-trigger,
  .nav-backdrop,
  .nav-sheet {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .float-nav-item--0,
    .float-nav-item--1,
    .float-nav-item--2 {
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .float-nav {
      position: static;
      top: auto;
      left: auto;
      transform: none;
      z-index: auto;
    }

    .float-nav-list {
      display: none;
    }

    .nav-trigger {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      bottom: 1.25rem;
      left: 50%;
      transform: translateX(-50%);
      width: 56px;
      height: 56px;
      border: none;
      border-radius: 50%;
      background: var(--color-accent-cyan-dark);
      color: #fff;
      cursor: pointer;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
      z-index: 300;
      transition: transform var(--transition-base), background-color var(--transition-base);
    }

    .nav-trigger:active {
      transform: translateX(-50%) scale(0.94);
    }

    .float-nav.is-open .nav-trigger {
      display: none;
    }

    .nav-trigger-icon {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 22px;
      height: 16px;
    }

    .nav-trigger-icon span {
      display: block;
      width: 100%;
      height: 2px;
      border-radius: 999px;
      background: currentColor;
      transform-origin: center;
      transition: transform var(--transition-base), opacity var(--transition-base);
    }

    .float-nav.is-open .nav-trigger-icon span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .float-nav.is-open .nav-trigger-icon span:nth-child(2) {
      opacity: 0;
    }

    .float-nav.is-open .nav-trigger-icon span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    .nav-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--transition-base);
      z-index: 200;
    }

    .float-nav.is-open .nav-backdrop {
      opacity: 1;
      pointer-events: auto;
    }

    .nav-sheet {
      display: flex;
      flex-direction: column;
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      max-height: 50vh;
      background: var(--color-bg-secondary);
      color: var(--color-text-primary);
      border-radius: 1.25rem 1.25rem 0 0;
      padding: 0.5rem 1.5rem calc(1.5rem + env(safe-area-inset-bottom));
      box-shadow: 0 -12px 30px rgba(0, 0, 0, 0.35);
      transform: translateY(100%);
      transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
      z-index: 250;
      overflow-y: auto;
    }

    .float-nav.is-open .nav-sheet {
      transform: translateY(0);
    }

    .nav-sheet-handle {
      width: 40px;
      height: 4px;
      margin: 0.6rem auto 1rem;
      border-radius: 999px;
      background: color-mix(in srgb, var(--color-text-primary) 25%, transparent);
      flex-shrink: 0;
    }

    .nav-sheet-close {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border: none;
      border-radius: 50%;
      background: color-mix(in srgb, var(--color-text-primary) 8%, transparent);
      color: var(--color-text-primary);
      cursor: pointer;
      transition: background-color var(--transition-base), color var(--transition-base);
    }

    .nav-sheet-close:hover,
    .nav-sheet-close:focus-visible {
      background: rgba(255, 255, 255, 0.16);
      color: var(--color-accent-cyan);
    }

    .nav-sheet-list {
      display: flex;
      flex-direction: column;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .nav-sheet-link {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      width: 100%;
      padding: 0.95rem 0.25rem;
      border: none;
      border-bottom: 1px solid color-mix(in srgb, var(--color-text-primary) 8%, transparent);
      background: transparent;
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: 1.05rem;
      color: var(--color-text-primary);
      text-align: left;
      cursor: pointer;
      transition: color var(--transition-base);
    }

    .nav-sheet-list li:last-child .nav-sheet-link {
      border-bottom: none;
    }

    .nav-sheet-link:hover,
    .nav-sheet-link:focus-visible {
      color: var(--color-accent-cyan);
    }
  }
</style>

<script>
  const themeToggles = document.querySelectorAll('.theme-toggle');

  themeToggles.forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const isLight = document.documentElement.getAttribute('data-theme') === 'light';

      if (isLight) {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
      }
    });
  });

  const floatNav = document.querySelector('.float-nav');
  const navTrigger = document.getElementById('nav-trigger');
  const navBackdrop = document.getElementById('nav-backdrop');
  const navSheet = document.getElementById('mobile-nav-sheet');

  if (floatNav && navTrigger && navBackdrop && navSheet) {
    const setOpen = (open: boolean) => {
      floatNav.classList.toggle('is-open', open);
      navTrigger.setAttribute('aria-expanded', String(open));
    };

    navTrigger.addEventListener('click', () => {
      setOpen(!floatNav.classList.contains('is-open'));
    });

    navBackdrop.addEventListener('click', () => setOpen(false));

    navSheet.querySelectorAll('a, button').forEach((el) => {
      el.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });
  }
</script>
