---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import avatar1 from '../assets/avatar.png';
import marqueeTech from '../data/tech-marquee.json';
import stack from '../data/stack.json';

const techIconImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/tech-icons/*.{png,jpg,jpeg,webp,svg}',
  { eager: true }
);

function getTechIcon(slug: string) {
  const entry = Object.entries(techIconImages).find(([path]) => {
    const filename = path.split('/').pop() ?? '';
    return filename.startsWith(`${slug}.`) || filename.startsWith(`${slug}-icon.`);
  });
  return entry?.[1]?.default;
}

const allExperience = await getCollection('experience');
const experience = [...allExperience].sort((a, b) => a.data.order - b.data.order);
---

<section id="about-me" class="section about">
  <div class="about-light">
    <div class="container">
      <h2 class="section-title">About <span>me</span></h2>
      <div class="about-bio" data-aos="fade-up">
        <div class="about-avatar">
          <Image src={avatar1} alt="Avatar" class="about-avatar-img" width={360} height={360} loading="lazy" />
        </div>

        <p>
          Frontend Developer with 4+ years of commercial experience, specializing in the Vue.js ecosystem and TypeScript, with working knowledge of React and Next.js. Experienced in building scalable, responsive web applications — from architecture decisions to performance optimization and REST API integration. Known for high attention to code quality, developer experience, and end-user performance across complex, high-traffic products.
        </p>
      </div>

      <div class="about-experience">
        <h3 class="about-subtitle" data-aos="fade-up">Experience</h3>
        <ul class="experience-list">
          {experience.map((entry, index) => (
            <li class="experience-item" data-aos="fade-up" data-aos-delay={index * 100}>
              <div class="experience-item-header">
                <h4 class="experience-item-role">{entry.data.position}</h4>
                <span class="experience-item-period">{entry.data.date}</span>
              </div>
              <p class="experience-item-company">{entry.data.place}</p>
              <ul class="experience-item-description">
                {entry.data.list.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<section id="stack" class="section stack-section">
  <div class="container">
    <h2 class="section-title">Tech <span>stack</span></h2>
    <div class="about-stack">
      <div class="stack-groups">
        {stack.map((group, index) => (
          <div class="stack-group" data-aos="fade-up" data-aos-delay={index * 100}>
            <h4 class="stack-group-title">{group.category}</h4>
            <ul class="stack-pills">
              {group.items.map((item) => (
                <li class="stack-pill">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="tech-marquee" aria-hidden="true" data-aos="fade-up">
        <div class="tech-marquee-track">
          {[...marqueeTech, ...marqueeTech].map((tech, index) => {
            const icon = getTechIcon(tech.icon);
            return (
              <span class="tech-marquee-item" title={tech.name}>
                {icon ? (
                  <Image src={icon} alt={tech.name} class="tech-marquee-icon-img" width={32} height={32} loading="lazy" />
                ) : (
                  <span
                    class="tech-marquee-icon"
                    style={`background: linear-gradient(135deg, ${
                      index % 2 === 0
                        ? 'var(--color-accent-cyan), var(--color-accent-pink)'
                        : 'var(--color-accent-pink), var(--color-accent-cyan)'
                    })`}
                  >
                    {tech.short}
                  </span>
                )}
              </span>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about.section {
    padding-block: 0;
  }

  .about-light {
    --color-bg-primary: var(--color-hero-bg-start);
    --color-text-primary: var(--color-hero-text-primary);
    --color-text-secondary: var(--color-hero-text-secondary);
    background-color: var(--color-hero-bg-start);
    background-image: radial-gradient(circle, rgba(3, 166, 163, 0.28) 1.6px, transparent 1.6px);
    background-size: 34px 34px;
    padding-block: var(--section-padding);
  }

  :global([data-theme='light'] .about-light) {
    --color-bg-secondary: #ffffff;
    --color-accent-cyan: var(--color-accent-cyan-dark);
  }

  .about-bio {
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--color-text-primary);
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }

  .about-bio p {
    max-width: 60ch;
  }

  .about-avatar {
    position: relative;
    flex-shrink: 0;
    width: clamp(10rem, 20vw, 16rem);
    height: clamp(10rem, 20vw, 16rem);
    border: 2px solid color-mix(in srgb, var(--color-accent-cyan) 40%, transparent);
    border-radius: 50%;
    background-color: var(--color-bg-secondary);
    overflow: hidden;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .about-avatar:hover {
    border-color: var(--color-accent-cyan);
    transform: scale(1.03);
  }

  .about-avatar-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .about-bio {
      flex-direction: column;
      text-align: center;
    }

    .experience-item-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .about-subtitle {
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    color: var(--color-text-primary);
    margin-bottom: 1.5rem;
  }

  .about-experience {
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .experience-item {
    position: relative;
    padding: 1.5rem;
    background-color: var(--color-bg-secondary);
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-text-primary) 6%, transparent);
    overflow: hidden;
  }

  .experience-item::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 35%;
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--color-accent-cyan) 8%, transparent) 60%,
      color-mix(in srgb, var(--color-accent-pink) 12%, transparent)
    );
    pointer-events: none;
  }

  .experience-item-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .experience-item-role {
    font-size: 1.1rem;
    color: var(--color-text-primary);
  }

  .experience-item-period {
    font-size: 0.875rem;
    color: var(--color-accent-cyan);
    font-weight: 600;
    font-family: var(--font-heading);
    white-space: nowrap;
  }

  .experience-item-company {
    font-weight: 600;
    color: var(--color-accent-pink);
    margin-bottom: 0.5rem;
  }

  .experience-item-description {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    list-style: none;
  }

  .experience-item-description li {
    position: relative;
    padding-left: 1rem;
  }

  .experience-item-description li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-accent-cyan), var(--color-accent-pink));
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .experience-item-description {
      padding-left: 0;
    }
  }

  .stack-groups {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .stack-group-title {
    font-size: 1rem;
    color: var(--color-accent-cyan);
    margin-bottom: 0.75rem;
  }

  .stack-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .stack-pill {
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    background-color: var(--color-bg-secondary);
    border: 1px solid color-mix(in srgb, var(--color-accent-cyan) 35%, transparent);
    color: var(--color-text-primary);
    font-size: 0.85rem;
    transition: border-color var(--transition-base), color var(--transition-base);
  }

  .stack-pill:hover {
    border-color: var(--color-accent-cyan);
    color: var(--color-accent-cyan);
  }

  .tech-marquee {
    margin-top: clamp(2rem, 5vw, 3rem);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .tech-marquee-track {
    display: flex;
    width: max-content;
    gap: 1rem;
    padding-block: 0.5rem;
    animation: tech-marquee-scroll 35s linear infinite;
  }

  .tech-marquee:hover .tech-marquee-track {
    animation-play-state: paused;
  }

  .tech-marquee-item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 0.9rem;
    background-color: var(--color-bg-secondary);
    border: 1px solid color-mix(in srgb, var(--color-accent-cyan) 35%, transparent);
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .tech-marquee-item:hover {
    border-color: var(--color-accent-cyan);
    transform: translateY(-3px);
  }

  .tech-marquee-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    font-size: 0.65rem;
    font-weight: 700;
    font-family: var(--font-heading);
    color: var(--color-bg-primary);
  }

  .tech-marquee-icon-img {
    width: 2rem;
    height: 2rem;
    object-fit: contain;
  }

  @keyframes tech-marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
</style>
